# Multiverse Codex local development environment
# Copy this file to .env and replace every placeholder before running the app.

# Phase 7 native PostgreSQL default database. Replace the password with the value
# used for MULTIVERSE_CODEX_DB_PASSWORD when running scripts/dev-db-create.sh.
DATABASE_URL=postgresql://multiverse_codex_app:replace-with-url-safe-hex-password@127.0.0.1:5432/multiverse_codex_dev

# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-64-hex-character-session-secret

# Public site name used by server-side configuration and later page metadata.
PUBLIC_SITE_NAME=Multiverse Codex

# Absolute path for local media storage. Phase 52 owns the full managed media tree;
# Phase 8 only reserves and validates the required variable.
MEDIA_ROOT=/tmp/multiverse-codex-media
